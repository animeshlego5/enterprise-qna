FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Bake the embedding model into the image so container startup is instant.
# Without this, each `docker compose up` downloads ~80MB from Hugging Face.
RUN python -c "from sentence_transformers import SentenceTransformer; SentenceTransformer('all-MiniLM-L6-v2')"

# api/ is included because workers/llm_worker.py imports api.logging_config.
COPY api/ api/
COPY pipeline/ pipeline/
COPY workers/ workers/

CMD ["python", "-m", "workers.llm_worker"]
